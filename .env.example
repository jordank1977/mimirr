# Database
# For local development
DATABASE_URL=file:./config/db.sqlite
# For Docker (automatically set in docker-compose.yml)
# DATABASE_URL=file:/app/config/db.sqlite

# JWT (auto-generated if not set, but recommended for production)
# Generate a secret: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Hardcover API (optional - for higher rate limits)
HARDCOVER_API_TOKEN=

# Note: On first launch, you'll create your admin account via the setup wizard
# No environment variables needed for initial setup!

# Application
NODE_ENV=development
PORT=3000
