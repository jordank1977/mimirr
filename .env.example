# Mimirr Environment Configuration
# This file is a template - all variables are OPTIONAL

# Database
# For local development (default)
DATABASE_URL=file:./config/db.sqlite
# For Docker (automatically set in docker-compose.yml)
# DATABASE_URL=file:/app/config/db.sqlite

# Application
NODE_ENV=development
PORT=3000

# ============================================
# ADVANCED CONFIGURATION (Optional)
# ============================================

# Sync Interval - Optional
# The background polling frequency for the Bookshelf (Readarr) library sync engine in minutes.
# Defaults to 15 if not set.
# SYNC_INTERVAL_MINUTES=15

# Note: On first launch, use the setup wizard to create your admin account
# No environment variables required!
