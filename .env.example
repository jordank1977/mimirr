# Database
# For local development
DATABASE_URL=file:./config/db.sqlite
# For Docker (automatically set in docker-compose.yml)
# DATABASE_URL=file:/app/config/db.sqlite

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Hardcover API (optional - for higher rate limits)
HARDCOVER_API_TOKEN=

# Default Admin (created on first run if no users exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme
DEFAULT_ADMIN_EMAIL=admin@localhost

# Application
NODE_ENV=development
PORT=3000
